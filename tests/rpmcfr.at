#    rpmcfr.at: test copy_file_range(2) payload install
#
#    An aligned uncompressed payload can be cloned or range-copied out of the
#    package on install while still verifying the copied file digest. On
#    filesystems supporting reflinks, the installed file shares its on-disk
#    extents with the package, which filefrag(8) reports.

AT_BANNER([RPM copy_file_range payloads])

# ------------------------------------------------------------------
# The fast path must retain normal per-file digest verification. This only
# requires copy_file_range() itself, not reflink/extent-sharing support.
RPMTEST_SETUP_RW([copy_file_range install verifies file digest])
AT_KEYWORDS([copyfilerange install digest])
RPMTEST_SKIP_IF([! { dd if=/dev/zero of=${RPMTEST}/tmp/rfp bs=4096 count=1 && rpmcfrprobe ${RPMTEST}/tmp/rfp ${RPMTEST}/tmp/rfp2; } >/dev/null 2>&1])
RPMTEST_CHECK([
runroot rpmbuild -bb --quiet \
	--define "_binary_payload w.ufdio" \
	--define "_payload_alignment 4096" \
	/data/SPECS/aligntest.spec

pkg=/build/RPMS/noarch/aligntest-1.0-1.noarch.rpm
runroot rpm -U --nodeps --nosignature --fsmdebug -vv ${pkg} 2>&1 |
	grep 'big.txt.*range copy' >/dev/null
runroot rpm -V --nodeps --nouser --nogroup aligntest >/dev/null
echo verified-copy-ok
runroot rpm -e --nodeps aligntest

cp ${RPMTEST}${pkg} ${RPMTEST}/build/aligntest-badcontent.rpm
rpmcorruptpad ${RPMTEST}/build/aligntest-badcontent.rpm 4096 content
badlog=${RPMTEST}/tmp/cfr-bad.log
if runroot rpm -U --nodeps --nosignature --nodigest \
	--fsmdebug -vv /build/aligntest-badcontent.rpm >${badlog} 2>&1; then
	exit 1
fi
grep 'big.txt.*range copy' ${badlog} >/dev/null
grep 'Digest mismatch' ${badlog} >/dev/null
echo copied-file-digest-rejected
],
[0],
[verified-copy-ok
copied-file-digest-rejected
],
[])
RPMTEST_CLEANUP

# ------------------------------------------------------------------
# An unaligned source offset prevents a clone and exercises bounded
# copy_file_range() fallback. A file spanning four chunks must produce
# intermediate install progress instead of one end-of-file jump.
RPMTEST_SETUP_RW([range copy fallback reports progress])
AT_KEYWORDS([copyfilerange install progress])
RPMTEST_SKIP_IF([! { dd if=/dev/zero of=${RPMTEST}/tmp/rfp bs=4096 count=1 && rpmcfrprobe ${RPMTEST}/tmp/rfp ${RPMTEST}/tmp/rfp2; } >/dev/null 2>&1])
RPMTEST_CHECK([
runroot rpmbuild -bb --quiet \
	--define "_binary_payload w.ufdio" \
	--define "_payload_alignment 8" \
	--define "_progress_test 1" \
	/data/SPECS/aligntest.spec

pkg=/build/RPMS/noarch/aligntest-1.0-1.noarch.rpm
hostpkg=${RPMTEST}${pkg}
contentoff=$(LC_ALL=C grep -aob 'progress-range-start' "${hostpkg}" |
	head -n 1 | cut -d: -f1)
membersize=$(runroot rpm -qp --qf \
	'[[%{filenames} %{longfilesizes}\n]]' "${pkg}" |
	awk '$1 == "/opt/aligntest/big.txt" { print $2 }')
test -n "${contentoff}"
test "${membersize}" = 67108864
],
[0],
[],
[])

RPMTEST_SKIP_IF([{
pkg=/build/RPMS/noarch/aligntest-1.0-1.noarch.rpm
hostpkg=${RPMTEST}${pkg}
contentoff=$(LC_ALL=C grep -aob 'progress-range-start' "${hostpkg}" |
	head -n 1 | cut -d: -f1)
membersize=$(runroot rpm -qp --qf \
	'[[%{filenames} %{longfilesizes}\n]]' "${pkg}" |
	awk '$1 == "/opt/aligntest/big.txt" { print $2 }')
! rpmcfrprobe "${hostpkg}" ${RPMTEST}/tmp/cfr-progress-probe \
	"${contentoff}" "${membersize}";
}])

RPMTEST_CHECK([
pkg=/build/RPMS/noarch/aligntest-1.0-1.noarch.rpm
progress=${RPMTEST}/tmp/cfr-progress
log=${RPMTEST}/tmp/cfr-progress.log
runroot rpm -U --nodeps --nosignature --percent --fsmdebug -vv ${pkg} \
	> "${progress}" 2> "${log}"
grep 'big.txt.*range copy' "${log}" >/dev/null
awk '$1 == "%%" && $2 > 20 && $2 < 80 { intermediate++ }
     END { if (intermediate < 2) exit 1 }' "${progress}"
echo progress-ok
],
[0],
[progress-ok
],
[])
RPMTEST_CLEANUP

# ------------------------------------------------------------------
# A raw package can share extents with the installed destination.
RPMTEST_SETUP_RW([range copy shares install extents])
AT_KEYWORDS([copyfilerange reflink install])
RPMTEST_SKIP_IF([! { dd if=/dev/zero of=${RPMTEST}/tmp/rfp bs=4096 count=1 && rpmcfrprobe ${RPMTEST}/tmp/rfp ${RPMTEST}/tmp/rfp2 && command -v filefrag && LC_ALL=C filefrag -v ${RPMTEST}/tmp/rfp2 | grep -qw shared; } >/dev/null 2>&1])
RPMTEST_CHECK([
runroot rpmbuild -bb --quiet \
	--define "_binary_payload w.ufdio" \
	--define "_payload_alignment 4096" \
	/data/SPECS/aligntest.spec

runroot rpm -U --nodeps --nosignature \
	/build/RPMS/noarch/aligntest-1.0-1.noarch.rpm
sync
LC_ALL=C filefrag -v ${RPMTEST}/opt/aligntest/big.txt | grep -qw shared && echo install-shared
],
[0],
[install-shared
],
[])
RPMTEST_CLEANUP
