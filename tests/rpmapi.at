AT_BANNER([RPM API tests])

RPMTEST_SETUP([[rpmReadPackage() with NULL ts]])
AT_KEYWORDS([[api signature]])
RPMTEST_CHECK([[
readpkgnullts /data/RPMS/hello-2.0-1.x86_64-signed.rpm
]],
[4],
[hello-2.0-1.x86_64
],
[warning: /data/RPMS/hello-2.0-1.x86_64-signed.rpm: Header OpenPGP V4 RSA/SHA256 signature, key ID 4344591e1964c5fc: NOKEY
])
RPMTEST_CLEANUP

RPMTEST_SETUP_RW([keystore API with wrong lock])
AT_KEYWORDS([api])
RPMTEST_CHECK([
runroot oldtxn
],
[0],
[],
[stderr])

RPMTEST_CHECK([
grep rpmtxnRebuildKeystore stderr
],
[0],
[D: rpmtxnRebuildKeystore: expected a keystore handle, got a transaction handle
],
[])
RPMTEST_CLEANUP

RPMTEST_SETUP_RW([rpmtsImportPubkey()])
AT_KEYWORDS([api signature import])
RPMTEST_CHECK([
runroot importkey /data/keys/rpm.org-rsa-2048-test.pub
],
[0],
[/data/keys/rpm.org-rsa-2048-test.pub key 1: 0
],
[])

RPMTEST_CHECK([
runroot importkey /data/keys/alice-revoked-subkey.asc
],
[0],
[/data/keys/alice-revoked-subkey.asc key 1: 0
],
[warning: Certificate B3A771BFEB04E625:
  Subkey 1F71177215217EE0 was revoked: Key material has been compromised, it was the maid
  Certificate does not have any usable signing keys
])

RPMTEST_CHECK([
runroot sed -i '/^nist/s/always/never/g' /etc/crypto-policies/back-ends/rpm-sequoia.config
runroot importkey /data/keys/rpm.org-nistp256-test.pub
],
[1],
[/data/keys/rpm.org-nistp256-test.pub key 1: 3
],
[error: Certificate 7F1C21F95F65BBE8:
  Policy rejects 7F1C21F95F65BBE8: Policy rejected asymmetric algorithm, because NistP256 is not considered secure
])
RPMTEST_CLEANUP

RPMTEST_SETUP([API symbol exports])
AT_KEYWORDS([api])
RPMTEST_CHECK([[
cd ${RPMTEST}/${RPMLIBDIR}
for f in librpm*.so.*.*; do
    echo ${f}:
    nm -D --defined-only ${f} | awk '/ T [[:alpha:]]/ { print("\t"$3) }' | head -3
done
]],
[0],
[librpm.so.10.8.0:
	headerAddI18NString@@LIBRPM_6.2
	headerCheck@@LIBRPM_6.2
	headerConvert@@LIBRPM_6.2
librpmbuild.so.10.8.0:
	rpmSpecBuild@@LIBRPMBUILD_6.2
	rpmSpecCheckDeps@@LIBRPMBUILD_6.2
	rpmSpecDS@@LIBRPMBUILD_6.2
librpmio.so.10.8.0:
	Fclose@@LIBRPMIO_6.2
	Fcntl@@LIBRPMIO_6.2
	Fdescr@@LIBRPMIO_6.2
librpmsign.so.10.8.0:
	rpmPkgDelFileSign@@LIBRPMSIGN_6.2
	rpmPkgDelSign@@LIBRPMSIGN_6.2
	rpmPkgSign@@LIBRPMSIGN_6.2
],
[])
RPMTEST_CLEANUP
