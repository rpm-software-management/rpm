#    rpmcfrpython.at: archive skip fallback API test

AT_BANNER([RPM archive skip fallback])

# A plain but nonseekable archive reader must fall back to reading skipped
# content instead of failing lseek(2).
RPMPY_TEST([archive skip handles nonseekable input],[
import os

pkg = rpm.fd.open('${RPMDATA}/RPMS/hello-2.0-1.x86_64.rpm')
h = ts.hdrFromFdno(pkg)
payload = rpm.fd.open(pkg, flags=h['payloadcompressor'])
files = rpm.files(h)
raw = payload.read()
readfd, writefd = os.pipe()
pid = os.fork()
if pid == 0:
    os.close(readfd)
    with os.fdopen(writefd, 'wb') as pipe:
        pipe.write(raw)
    os._exit(0)

os.close(writefd)
pipe = rpm.fd(readfd, 'r', 'ufdio')
os.close(readfd)
pipe_reader = files.archive(pipe)
for f in pipe_reader:
    pass
_, status = os.waitpid(pid, 0)
if status != 0:
    raise RuntimeError('pipe writer failed')
print('pipe-skip-ok')
],[pipe-skip-ok
],[])
