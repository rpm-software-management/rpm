#    rpmalign.at: test block-aligned payloads
#
#    An aligned payload records RPMTAG_PAYLOADALIGNMENT and lays out regular
#    file content on an alignment boundary using an RPM-specific cpio extension.

AT_BANNER([RPM aligned payloads])

# A compressed aligned payload records the format tag and reader requirement.
# Its canonical digest is independent of the compression algorithm.
RPMTEST_SETUP_RW([aligned compressed payload format])
AT_KEYWORDS([align build payload])
RPMTEST_CHECK([
runroot rpmbuild -bb --quiet \
	--define "_binary_payload w3.zstdio" \
	--define "_payload_alignment 4096" \
	--define "_rpmformat 6" \
	/data/SPECS/aligntest.spec

pkg=/build/RPMS/noarch/aligntest-1.0-1.noarch.rpm
runroot rpm -qp --qf "%{payloadcompressor} %{payloadalignment}\n" ${pkg}
runroot rpm -qp --requires ${pkg} | grep '^rpmlib(PayloadAlignment)'
zstd=$(runroot rpm -qp --qf "%{payloadsha256alt}" ${pkg})

runroot rpmbuild -bb --quiet \
	--define "_binary_payload w9.gzdio" \
	--define "_payload_alignment 4096" \
	--define "_rpmformat 6" \
	/data/SPECS/aligntest.spec
gzip=$(runroot rpm -qp --qf "%{payloadsha256alt}" ${pkg})
test "$gzip" = "$zstd" && echo alt-digest-canonical
],
[0],
[zstd 4096
rpmlib(PayloadAlignment) <= 6.2.0-1
alt-digest-canonical
],
[])
RPMTEST_CLEANUP

# Invalid and impractically large alignments must fail rather than silently
# disabling the requested format or allocating an enormous padding buffer.
RPMTEST_SETUP_RW([aligned payload validation])
AT_KEYWORDS([align build])
RPMTEST_CHECK([
runroot rpmbuild -bb --quiet \
	--define "_payload_alignment 1048576" \
	/data/SPECS/aligntest.spec
pkg=/build/RPMS/noarch/aligntest-1.0-1.noarch.rpm
test "$(runroot rpm -qp --qf '%{payloadalignment}' ${pkg})" = 1048576 && \
	echo maximum-alignment-accepted

for alignment in -1 3 2097152; do
	if runroot rpmbuild -bb --quiet \
		--define "_payload_alignment ${alignment}" \
		/data/SPECS/aligntest.spec >/dev/null 2>&1; then
		exit 1
	fi
	echo invalid-${alignment}-rejected
done

],
[0],
[maximum-alignment-accepted
invalid--1-rejected
invalid-3-rejected
invalid-2097152-rejected
],
[])
RPMTEST_CLEANUP

# Raw payload framing is physical representation data: primary digests and
# size include it, while ALT describes the same canonical cpio as compression.
RPMTEST_SETUP_RW([aligned raw payload representation])
AT_KEYWORDS([align build payload raw digest])
RPMTEST_CHECK([
runroot rpmbuild -bb --quiet \
	--define "_binary_payload w.ufdio" \
	--define "_payload_alignment 65536" \
	--define "_rpmformat 6" \
	/data/SPECS/aligntest.spec
pkg=/build/RPMS/noarch/aligntest-1.0-1.noarch.rpm
rawalt=$(runroot rpm -qp --qf "%{payloadsha256alt}" ${pkg})
rawprimary=$(runroot rpm -qp --qf "%{payloadsha256}" ${pkg})
rawaltsize=$(runroot rpm -qp --qf "%{payloadsizealt}" ${pkg})
test "$rawprimary" != "$rawalt" && echo framing-has-primary-identity
runroot rpmkeys -K --nosignature ${pkg} >/dev/null && echo raw-digests-ok

runroot rpmbuild -bb --quiet \
	--define "_binary_payload w3.zstdio" \
	--define "_payload_alignment 65536" \
	--define "_rpmformat 6" \
	/data/SPECS/aligntest.spec
zstdalt=$(runroot rpm -qp --qf "%{payloadsha256alt}" ${pkg})
zstdaltsize=$(runroot rpm -qp --qf "%{payloadsizealt}" ${pkg})
test "$zstdalt" = "$rawalt" && echo alt-digest-canonical
test "$zstdaltsize" = "$rawaltsize" && echo alt-size-canonical
],
[0],
[framing-has-primary-identity
raw-digests-ok
alt-digest-canonical
alt-size-canonical
],
[])
RPMTEST_CLEANUP

# Both RPM payload header formats install and verify from aligned raw cpio.
RPMTEST_SETUP_RW([aligned raw payload install])
AT_KEYWORDS([align install raw v4 v6])
RPMTEST_CHECK([
for format in 4 6; do
	runroot rpmbuild -bb --quiet \
		--define "_binary_payload w.ufdio" \
		--define "_payload_alignment 4096" \
		--define "_rpmformat ${format}" \
		/data/SPECS/aligntest.spec
	runroot rpm -U --replacepkgs --nodeps --nosignature \
		/build/RPMS/noarch/aligntest-1.0-1.noarch.rpm
	runroot rpm -V --nodeps --nouser --nogroup aligntest >/dev/null
	echo verify-v${format}-ok
done
],
[0],
[verify-v4-ok
verify-v6-ok
],
[])
RPMTEST_CLEANUP

# Aligned member padding is structural and must be entirely zero-filled.
RPMTEST_SETUP_RW([aligned payload rejects nonzero padding])
AT_KEYWORDS([align payload corrupt raw v4 v6])
RPMTEST_CHECK([
for format in 4 6; do
	runroot rpmbuild -bb --quiet \
		--define "_binary_payload w.ufdio" \
		--define "_payload_alignment 4096" \
		--define "_rpmformat ${format}" \
		/data/SPECS/aligntest.spec
	pkg=/build/RPMS/noarch/aligntest-1.0-1.noarch.rpm
	cp ${RPMTEST}${pkg} ${RPMTEST}/build/aligntest-v${format}-badpad.rpm
	rpmcorruptpad ${RPMTEST}/build/aligntest-v${format}-badpad.rpm 4096
	if runroot rpm2archive /build/aligntest-v${format}-badpad.rpm \
		>/dev/null 2>&1; then
		exit 1
	fi
	echo bad-padding-v${format}-rejected
done
],
[0],
[bad-padding-v4-rejected
bad-padding-v6-rejected
],
[])
RPMTEST_CLEANUP

# Exercise both payload header formats through decompression, installation and
# file verification. v4 uses full cpio headers while v6 uses stripped headers.
RPMTEST_SETUP_RW([aligned compressed payload install])
AT_KEYWORDS([align install v4 v6])
RPMTEST_CHECK([
for format in 4 6; do
	runroot rpmbuild -bb --quiet \
		--define "_binary_payload w3.zstdio" \
		--define "_payload_alignment 4096" \
		--define "_rpmformat ${format}" \
		/data/SPECS/aligntest.spec
	runroot rpm -U --replacepkgs --nodeps --nosignature \
		/build/RPMS/noarch/aligntest-1.0-1.noarch.rpm
	runroot rpm -V --nodeps --nouser --nogroup aligntest >/dev/null
	echo verify-v${format}-ok
done
],
[0],
[verify-v4-ok
verify-v6-ok
],
[])
RPMTEST_CLEANUP

# Only regular files are aligned. A symlink target longer than this small
# alignment must remain inline on the stripped v6 read path.
RPMTEST_SETUP_RW([aligned compressed payload small alignment])
AT_KEYWORDS([align install v6])
RPMTEST_CHECK([
runroot rpmbuild -bb --quiet \
	--define "_binary_payload w3.zstdio" \
	--define "_payload_alignment 8" \
	--define "_rpmformat 6" \
	/data/SPECS/aligntest.spec
runroot rpm -U --replacepkgs --nodeps --nosignature \
	/build/RPMS/noarch/aligntest-1.0-1.noarch.rpm
runroot rpm -V --nodeps --nouser --nogroup aligntest >/dev/null && echo verify-ok
],
[0],
[verify-ok
],
[])
RPMTEST_CLEANUP
